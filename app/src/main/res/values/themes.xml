<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.MyToDoList" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Make header text (Month + Year) white -->
        <item name="android:textColorPrimary">@android:color/white</item>
        <item name="android:textColorSecondary">@android:color/white</item>

        <!-- Make navigation arrows white -->
        <item name="colorOnSurface">@android:color/white</item>

    </style>

    <style name="WhiteWeekText">
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="WhiteDateText">
        <item name="android:textColor">@android:color/white</item>
    </style>
    <style name="CustomChipStyle" parent="Widget.Material3.Chip.Assist">
        <item name="chipBackgroundColor">@color/mediumGreen</item>
        <item name="android:textColor">@color/textWhite</item>
        <item name="closeIconTint">@color/textWhite</item>
        <item name="chipStrokeWidth">0dp</item>
    </style>

</resources>