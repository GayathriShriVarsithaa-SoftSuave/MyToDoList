<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.mytodolist.home.HomeFragment">
        <action
            android:id="@+id/homeToSearch"
            app:destination="@id/searchFragment" />
        <action
            android:id="@+id/homeToDetail"
            app:destination="@id/detailFragment" >
            <argument
                android:name="taskId"
                app:argType="long" />
        </action>
    </fragment>
    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.mytodolist.search.SearchFragment">
        <action
            android:id="@+id/searchToHome"
            app:destination="@id/homeFragment"/>
    </fragment>
    <fragment
        android:id="@+id/detailFragment"
        android:name="com.example.mytodolist.detail.DetailFragment">
        <argument
            android:name="taskId"
            app:argType="long"/>
        <action
            android:id="@+id/detailToHome"
            app:destination="@id/homeFragment"/>
    </fragment>
</navigation>